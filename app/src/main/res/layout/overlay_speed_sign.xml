<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/speedometerSignRoot"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="8dp"
    android:background="@drawable/speedometer_bg"
    android:gravity="center_vertical">

    <FrameLayout
        android:id="@+id/signContainer"
        android:layout_width="48dp"
        android:layout_height="48dp">

        <ImageView
            android:id="@+id/imgLimitSign"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:src="@drawable/speed_sign_background" />

        <TextView
            android:id="@+id/txtLimitSign"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textColor="@android:color/black"
            android:textSize="18sp" />
    </FrameLayout>

    <ImageView
        android:id="@+id/imgMuteState"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginStart="6dp"
        android:layout_gravity="center_vertical"
        android:src="@drawable/ic_volume_on"/>

    <TextView
        android:id="@+id/txtSpeedSign"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="32sp"
        android:textColor="#FFFFFF"
        android:paddingStart="12dp" />

    <ImageView
        android:id="@+id/imgCameraWarning"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_margin="4dp"
        android:layout_gravity="top|end"
        android:elevation="20dp"
        android:visibility="gone" />

</LinearLayout>
