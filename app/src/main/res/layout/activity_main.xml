<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- START / STOP BUTTONS -->
        <LinearLayout
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStart"
                android:text="@string/btn_start_service"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:icon="@drawable/ic_start"
                app:iconGravity="textStart"
                app:iconPadding="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStop"
                android:text="@string/btn_stop_service"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:icon="@drawable/ic_stop"
                app:iconGravity="textStart"
                app:iconPadding="12dp" />
        </LinearLayout>


        <!-- SETTINGS HEADER -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/headerSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/section_settings"
            android:textSize="18sp"
            android:padding="12dp"
            app:icon="@drawable/ic_settings"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            android:layout_marginBottom="8dp" />

        <!-- SETTINGS CONTENT -->
        <LinearLayout
            android:id="@+id/layoutSettingsContent"
            android:orientation="vertical"
            android:visibility="gone"
            android:padding="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <Switch
                android:id="@+id/switchSpeedo"
                android:text="@string/switch_show_speedo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <Switch
                android:id="@+id/switchTransparency"
                android:text="@string/switch_transparency"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <Switch
                android:id="@+id/switchMph"
                android:text="@string/switch_use_mph"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <Switch
                android:id="@+id/switchBroadcast"
                android:text="@string/broadcast_switch_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/textOverspeedValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5%"
                android:textSize="18sp"
                android:paddingTop="16dp" />

            <com.google.android.material.slider.Slider
                android:id="@+id/sliderOverspeed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="0"
                android:valueTo="25"
                android:stepSize="1"
                android:value="5" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSavePercent"
                android:text="@string/btn_save_percent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp" />

            <LinearLayout
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSelectSound"
                    android:text="@string/btn_select_sound"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnResetSound"
                    android:text="@string/btn_reset_sound"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />
            </LinearLayout>

        </LinearLayout>


        <!-- TEST TOOLS HEADER -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/headerTools"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/section_test_tools"
            android:textSize="18sp"
            android:padding="12dp"
            app:icon="@drawable/ic_tools"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp" />

        <!-- TEST TOOLS CONTENT -->
        <LinearLayout
            android:id="@+id/layoutToolsContent"
            android:orientation="vertical"
            android:visibility="gone"
            android:padding="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

                <LinearLayout
                        android:orientation="horizontal"
                        android:weightSum="3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnTestSound"
                            android:text="@string/btn_test_sound"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnTestToast"
                            android:text="@string/btn_test_toast"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnTestNotification"
                            android:text="@string/btn_test_notification"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1" />

                    </LinearLayout>

        </LinearLayout>

        <!-- DEBUG HEADER -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/debugheader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/section_debug"
            android:textSize="18sp"
            android:padding="12dp"
            app:icon="@drawable/ic_debug"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp" />

        <!-- DEBUG CONTENT -->
        <LinearLayout
            android:id="@+id/debugContent"
            android:orientation="vertical"
            android:visibility="gone"
            android:padding="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/textCurrentSpeed"
                android:text="Speed: -- km/h"
                android:textSize="18sp"
                android:paddingTop="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/textSpeedLimit"
                android:text="Limit: -- km/h"
                android:textSize="18sp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/textDebug"
                android:text="Service: stopped"
                android:textSize="16sp"
                android:paddingTop="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/textDebugService"
                android:text="Service: unknown"
                android:textSize="16sp"
                android:paddingTop="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/textDebugPermissions"
                android:text="Permissions: checking..."
                android:textSize="14sp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/textDebugGps"
                android:text="GPS: waiting..."
                android:textSize="14sp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

        </LinearLayout>


        <!-- DISCLAIMER HEADER -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/headerDisclaimer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/section_disclaimer"
            android:textSize="18sp"
            android:padding="12dp"
            app:icon="@drawable/ic_info"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            android:layout_marginTop="20dp" />

        <!-- DISCLAIMER CONTENT -->
        <LinearLayout
            android:id="@+id/layoutDisclaimerContent"
            android:orientation="vertical"
            android:visibility="gone"
            android:padding="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- <TextView
                android:id="@+id/txtDisclaimerHeader"
                android:text="@string/disclaimer_header"
                android:textStyle="bold"
                android:textSize="16sp"
                android:paddingBottom="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" /> -->

            <TextView
                android:id="@+id/txtDisclaimerBody"
                android:text="@string/disclaimer_body"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="?attr/colorError"
                android:paddingTop="4dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
